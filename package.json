{
  "name": "mon-profil-anssi",
  "version": "1.0.0",
  "module": "nodenext",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "start:clever-cloud": "pnpm run pre-start:knex-migrate-latest && node --require dotenv/config dist/src/serveur.js",
    "start:local": "NODE_ENV=development pnpm run pre-start:knex-migrate-latest && NODE_ENV=development nodemon --require dotenv/config src/serveur.ts",
    "pre-start:knex-migrate-latest": "tsx --require dotenv/config ./node_modules/knex/bin/cli.js migrate:latest",
    "test": "node --import tsx --test './tests/**/*.spec.ts'",
    "test:watch": "node --watch --import tsx --test './tests/**/*.spec.ts'",
    "genere-documentation": "mkdir -p dist/public & node --import tsx ./src/api/swagger.ts",
    "preinstall": "npx only-allow@1.2.2 pnpm"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/betagouv/mon-profil-anssi.git"
  },
  "author": "",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/betagouv/mon-profil-anssi/issues"
  },
  "homepage": "https://github.com/betagouv/mon-profil-anssi#readme",
  "dependencies": {
    "@lab-anssi/lib": "2.1.3",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "pg": "^8.20.0",
    "redoc-express": "^2.1.3",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.15",
    "@types/supertest": "^6.0.3",
    "node-mocks-http": "^1.17.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "swagger-autogen": "^2.23.7",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0"
  },
  "pnpm": {
    "overrides": {
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
      "axios": "1.13.5",
      "lodash": "4.17.23",
      "qs@>=6.7.0 <=6.14.1": ">=6.14.2",
      "diff": "4.0.4"
    }
  }
}
